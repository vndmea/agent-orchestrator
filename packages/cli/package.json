{
  "name": "@agent-orchestrator/cli",
  "version": "0.1.0",
  "description": "Agent Orchestrator CLI for controlled host-worker workflows over local repositories.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ao": "./dist/main.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "pnpm --dir ../.. --filter @agent-orchestrator/cli... build"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.74",
    "@langchain/langgraph": "^1.4.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@commander-js/extra-typings": "^15.0.0",
    "ai": "^6.0.209",
    "commander": "^15.0.0",
    "zod": "^4.1.12"
  },
  "publishConfig": {
    "access": "public"
  }
}
